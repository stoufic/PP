# ============================================
# Allurion Smart Scale Integration
# Environment Configuration
# ============================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/allurion?schema=public"

# Vendor API Configuration (e.g., Withings)
VENDOR_CLIENT_ID="your_oauth_client_id"
VENDOR_CLIENT_SECRET="your_oauth_client_secret"
VENDOR_TOKEN_URL="https://api.vendor.com/oauth2/token"
VENDOR_API_BASE_URL="https://api.vendor.com/v2"
VENDOR_WEBHOOK_SECRET="your_webhook_hmac_secret"

# Application
NODE_ENV="development"
PORT=3000

# JWT Auth (if not already configured globally)
JWT_SECRET="your_jwt_secret_key_here"
JWT_EXPIRES_IN="7d"

# AWS (for S3 exports, CloudWatch logging)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="allurion-scale-exports"

# Rate Limiting
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"

# CORS (adjust for your mobile app domains)
CORS_ORIGINS="https://app.allurion.com,https://admin.allurion.com"

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"

# Sync Job Configuration
SYNC_ENABLED="true"
SYNC_CRON_EXPRESSION="*/15 * * * *" # Every 15 minutes
